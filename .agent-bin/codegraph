#!/usr/bin/env bash
set -euo pipefail
log="${CODEGRAPH_USAGE_LOG:-/home/runner/work/trackstate/trackstate/.dmtools/codegraph-usage.log}"
mkdir -p "$(dirname "${log}")"
printf '%s\tcodegraph' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" >> "${log}"
for arg in "$@"; do
  printf ' %q' "${arg}" >> "${log}"
done
printf '\n' >> "${log}"
exec "/home/runner/.npm-global/bin/codegraph" "$@"
